<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="mathPU">

        <provider>
            org.hibernate.jpa.HibernatePersistenceProvider
        </provider>

        <properties>

            <!-- Driver -->

            <property
                name="jakarta.persistence.jdbc.driver"
                value="org.postgresql.Driver"/>

            <!-- URL -->

            <property
                name="jakarta.persistence.jdbc.url"
                value="jdbc:postgresql://localhost:5432/mathlms"/>

            <!-- Usuario PostgreSQL -->

            <property
                name="jakarta.persistence.jdbc.user"
                value="postgres"/>

            <!-- Password PostgreSQL -->

            <property
                name="jakarta.persistence.jdbc.password"
                value="chilaquiles"/>

            <!-- Hibernate -->

            <property
                name="hibernate.hbm2ddl.auto"
                value="update"/>

            <property
                name="hibernate.show_sql"
                value="true"/>

            <property
                name="hibernate.format_sql"
                value="true"/>

        </properties>

    </persistence-unit>

</persistence>